#!/bin/bash
# Pre-push hook: build the site and check internal links via Docker.
# Mirrors scripts/test.sh so local checks match CI.
#
# Skip: SKIP_LINK_CHECK=1 git push

if [[ "${SKIP_LINK_CHECK}" == "1" ]]; then
    echo "[pre-push] SKIP_LINK_CHECK=1 set — skipping link check."
    exit 0
fi

# Check Docker is running
if ! docker info > /dev/null 2>&1; then
    echo ""
    echo "[pre-push] ⚠  Docker Desktop is not running."
    echo "           Start Docker Desktop to enable pre-push link checking."
    echo "           To skip the check and push anyway: SKIP_LINK_CHECK=1 git push"
    echo ""
    read -r -p "           Push without running the link check? [y/N] " reply < /dev/tty
    echo ""
    if [[ "${reply}" =~ ^[Yy]$ ]]; then
        echo "[pre-push] Skipping link check — CI will catch any broken links."
        exit 0
    else
        echo "[pre-push] Push cancelled. Start Docker Desktop and try again."
        exit 1
    fi
fi

echo "[pre-push] Running site build and link check..."
if ! bash "$(git rev-parse --show-toplevel)/scripts/test.sh"; then
    echo ""
    echo "[pre-push] Link check failed. Fix the errors above before pushing."
    exit 1
fi

echo "[pre-push] All checks passed."
